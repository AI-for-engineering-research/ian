{
  "name": "ai-research-class-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "citations": "node scripts/generate-citations.ts",
    "add-log": "node scripts/add-log.ts",
    "test": "node --test test/*.test.ts",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/mdx": "latest",
    "@fontsource/stix-two-text": "latest",
    "astro": "latest",
    "katex": "latest",
    "rehype-katex": "latest",
    "remark-math": "latest",
    "typescript": "latest",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2"
  }
}
