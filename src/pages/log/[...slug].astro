---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { withBase } from '../../lib/sitePaths.ts';

export async function getStaticPaths() {
  const numericPrefix = (id: string) => {
    const match = id.match(/^(\d+)/);
    return match ? Number.parseInt(match[1], 10) : Number.NEGATIVE_INFINITY;
  };

  const entries = (await getCollection('log', ({ data }) => !data.draft)).sort((a, b) => {
    const dateComparison = a.data.date.valueOf() - b.data.date.valueOf();
    if (dateComparison !== 0) return dateComparison;

    return numericPrefix(a.id) - numericPrefix(b.id);
  });
  return entries.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      previous: entries[index - 1],
      next: entries[index + 1],
    },
  }));
}

const { entry, previous, next } = Astro.props;
const { Content } = await render(entry);

const previousLink = previous ? { href: withBase(`/log/${previous.id}/`), label: previous.data.title } : undefined;
const nextLink = next ? { href: withBase(`/log/${next.id}/`), label: next.data.title } : undefined;
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.summary}
  date={entry.data.date}
  eyebrow="Research log"
  showDescription={false}
  previous={previousLink}
  next={nextLink}
>
  <Content />
</ContentLayout>
