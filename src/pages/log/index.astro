---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

const entries = (await getCollection('log', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<ContentLayout title="Research log" description="Session-by-session notes about interactions with coding agents and AI research tools.">
  <ul class="card-list">
    {entries.map((entry) => (
      <li class="card">
        <h2><a href={`/log/${entry.id}/`}>{entry.data.title}</a></h2>
        <p class="content-meta"><time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}</time></p>
        {entry.data.summary && <p>{entry.data.summary}</p>}
        {(entry.data.tags.length > 0 || entry.data.agents.length > 0) && (
          <ul class="tag-list">
            {entry.data.agents.map((agent) => <li>agent: {agent}</li>)}
            {entry.data.tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
</ContentLayout>
