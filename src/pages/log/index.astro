---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { withBase } from '../../lib/sitePaths.ts';

const numericPrefix = (id: string) => {
  const match = id.match(/^(\d+)/);
  return match ? Number.parseInt(match[1], 10) : Number.NEGATIVE_INFINITY;
};

const entries = (await getCollection('log', ({ data }) => !data.draft)).sort((a, b) => {
  const dateComparison = b.data.date.valueOf() - a.data.date.valueOf();
  if (dateComparison !== 0) return dateComparison;

  return numericPrefix(b.id) - numericPrefix(a.id);
});
---

<ContentLayout title="Research log" description="Session-by-session notes about interactions with coding agents and AI research tools.">
  <table class="log-index">
    <tbody>
      {entries.map((entry) => (
        <tr>
          <td><a href={withBase(`/log/${entry.id}/`)}>{entry.data.title}</a></td>
          <td><time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}</time></td>
        </tr>
      ))}
    </tbody>
  </table>
</ContentLayout>

<style>
  .log-index {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
  }

  .log-index td {
    padding: 0.25rem 0;
    vertical-align: baseline;
  }

  .log-index td:last-child {
    padding-left: 1.5rem;
    text-align: right;
    white-space: nowrap;
  }
</style>
