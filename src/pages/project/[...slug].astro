---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { withBase } from '../../lib/sitePaths.ts';

export async function getStaticPaths() {
  const pages = (await getCollection('project', ({ data }) => !data.draft))
    .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title));
  return pages.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      previous: pages[index - 1],
      next: pages[index + 1],
    },
  }));
}

const { entry, previous, next } = Astro.props;
const { Content } = await render(entry);

const previousLink = previous ? { href: withBase(`/project/${previous.id}/`), label: previous.data.title } : undefined;
const nextLink = next ? { href: withBase(`/project/${next.id}/`), label: next.data.title } : undefined;
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.summary}
  eyebrow="Project"
  showDescription={false}
  previous={previousLink}
  next={nextLink}
>
  <Content />
</ContentLayout>
