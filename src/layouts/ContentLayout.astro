---
import SiteLayout from './SiteLayout.astro';

export interface ContentNavLink {
  href: string;
  label: string;
}

export interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  date?: Date;
  dateFormat?: Intl.DateTimeFormatOptions;
  showDescription?: boolean;
  previous?: ContentNavLink;
  next?: ContentNavLink;
}

const { title, description, eyebrow, date, dateFormat, showDescription = true, previous, next } = Astro.props;
const formattedDate = date?.toLocaleString('en', dateFormat ?? { year: 'numeric', month: 'long', day: 'numeric' });
---

<SiteLayout title={title} description={description}>
  <article class="article-layout content-page">
    <header class="content-header">
      {eyebrow && <p class="content-meta">{eyebrow}</p>}
      <h1>{title}</h1>
      {formattedDate && <p class="content-meta"><time datetime={date?.toISOString()}>{formattedDate}</time></p>}
      {showDescription && description && <p>{description}</p>}
    </header>
    <slot />
    {(previous || next) && (
      <nav class="content-pagination" aria-label="Adjacent pages">
        {previous ? (
          <a class="content-pagination__link content-pagination__link--previous" href={previous.href} rel="prev">
            <span class="content-pagination__direction">Previous</span>
            <span class="content-pagination__title">{previous.label}</span>
          </a>
        ) : <span></span>}
        {next ? (
          <a class="content-pagination__link content-pagination__link--next" href={next.href} rel="next">
            <span class="content-pagination__direction">Next</span>
            <span class="content-pagination__title">{next.label}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}
  </article>
</SiteLayout>
