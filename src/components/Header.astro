---
import { withBase } from '../lib/sitePaths.ts';

const links = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/bio/'), label: 'Bio' },
  { href: withBase('/log/'), label: 'Research log' },
  { href: withBase('/project/'), label: 'Project' },
];
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">
    <a class="site-title" href={withBase('/')}>AI Tools in Research Pilot — Summer 2026</a>
    <div class="site-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </nav>
</header>
